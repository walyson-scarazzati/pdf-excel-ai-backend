# IA opcional. Deixe em branco se for usar apenas OCR local.
AI_PROVIDER=github-models
AI_API_URL=https://models.github.ai/inference/chat/completions
AI_API_KEY=
AI_MODEL=openai/gpt-4.1-mini
AI_GITHUB_API_VERSION=2026-03-10

# OCR local
OCR_ENABLED=true
OCR_COMMAND=tesseract
OCR_MODE=auto
OCR_LANGUAGE=por
OCR_PSM=4
OCR_TIMEOUT_SECONDS=25
OCR_MAX_PAGES=5
OCR_PREPROCESS_ENABLED=true
OCR_CONTRAST_FACTOR=1.35
OCR_THRESHOLD=168
OCR_UPSCALE_FACTOR=2
OCR_DESKEW_ENABLED=true
OCR_MAX_DESKEW_ANGLE=3.0
OCR_CROP_TOP_RATIO=0.12
OCR_CROP_BOTTOM_RATIO=0.03
OCR_CROP_SIDE_RATIO=0.03

APP_CORS_ALLOWED_ORIGINS=http://localhost:4200

# Banco local usado pelo Docker Compose
DB_HOST=postgres
DB_PORT=5432
DB_NAME=pdf_excel_ai
DB_USERNAME=pdf_excel_ai
DB_PASSWORD=pdf_excel_ai
DB_URL=jdbc:postgresql://${DB_HOST}:${DB_PORT}/${DB_NAME}

# Supabase/Render:
# DB_URL precisa ser uma URL JDBC completa, nao apenas o host.
# No Render, prefira o Session Pooler do Supabase porque a conexao direta usa IPv6 por padrao.
# Copie a connection string em Supabase > Connect > Pooler settings > Session pooler
# e converta de postgresql:// para jdbc:postgresql://.
#
# Exemplo Session Pooler:
# DB_URL=jdbc:postgresql://aws-0-<region>.pooler.supabase.com:5432/postgres?sslmode=require
# DB_USERNAME=postgres.<project-ref>
# DB_PASSWORD=<sua-senha>
#
# Exemplo conexao direta, apenas se sua plataforma tiver IPv6 ou voce ativar o IPv4 add-on:
# DB_URL=jdbc:postgresql://db.<project-ref>.supabase.co:5432/postgres?sslmode=require
# DB_USERNAME=postgres
# DB_PASSWORD=<sua-senha>
